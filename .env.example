# ════════════════════════════════════════════════════════════════════════════
#  NEXUS Kia'i — Environment Variables
#  Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────
# asyncpg connection string for PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nexus

# ── Azure AD (MSAL) ───────────────────────────────────────────────────────
# Azure tenant for ULU Malu Systems
AZURE_TENANT_ID=dd59f285-3eee-4150-8bfa-91bd8a96a83b
# App Registration client ID (Kia'i Knowledge Source)
AZURE_CLIENT_ID=d66cf553-c981-415b-8e49-55792547a917

# ── Guardian AI (Azure AI Foundry) ────────────────────────────────────────
GUARDIAN_ENDPOINT=https://ai-xgsn7koaekgj6.services.ai.azure.com/api/projects/proj-default
GUARDIAN_API_KEY=your_guardian_api_key_here

# ── CORS ──────────────────────────────────────────────────────────────────
# JSON array of allowed origins for the React frontend
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── App ───────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── LLM Providers (optional — for agent tasks) ────────────────────────────
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Azure OpenAI (alternative to OpenAI direct)
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-15-preview

GOOGLE_API_KEY=your_google_key_here
XAI_API_KEY=your_xai_key_here

# ── Azure Key Vault (optional — use instead of env vars for secrets) ───────
KEY_VAULT_URL=https://ulu-malu-kv.vault.azure.net/

# ── Vite frontend (VITE_ prefix is required for browser exposure) ──────────
# Set this in your .env to point the React app at the running backend
VITE_API_URL=http://localhost:8000
