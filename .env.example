# Local dev env settings (copy to .env)

# Option A: set directly
XAI_API_KEY="your_key_here"

# Optional: switch providers
LLM_PROVIDER="xai"
LLM_MODEL=""

# OpenAI
OPENAI_API_KEY="your_key_here"

# Azure OpenAI
AZURE_OPENAI_API_KEY="your_key_here"
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com"
AZURE_OPENAI_DEPLOYMENT="your-deployment-name"
AZURE_OPENAI_API_VERSION="2024-02-15-preview"

# Anthropic
ANTHROPIC_API_KEY="your_key_here"

# Google Gemini
GOOGLE_API_KEY="your_key_here"

# Option B: use Azure Key Vault (secret name must be XAI_API_KEY)
KEY_VAULT_URL="https://your-vault-name.vault.azure.net/"

# Optional: override secret names in Key Vault
# KEY_VAULT_SECRET_OPENAI_API_KEY="OPENAI-API-KEY"
# KEY_VAULT_SECRET_AZURE_OPENAI_API_KEY="AZURE-OPENAI-API-KEY"
# KEY_VAULT_SECRET_ANTHROPIC_API_KEY="ANTHROPIC-API-KEY"
# KEY_VAULT_SECRET_GOOGLE_API_KEY="GOOGLE-API-KEY"
